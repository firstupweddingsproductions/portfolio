---
import { routes, getAlternateLocaleUrl, type Lang } from '../i18n/routes';
import { t } from '../i18n/ui';
import { CATEGORIES, catLabel } from '../data/projects';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const path = Astro.url.pathname;
const norm = path.replace(/\/+$/, '') || '/';
const home = routes[lang].home;
const about = routes[lang]['ueber-mich'];
const contact = routes[lang].kontakt;
const alternateHref = getAlternateLocaleUrl(path, lang);

function isPage(href: string): boolean {
  const target = href.replace(/\/+$/, '') || '/';
  return norm === target;
}

const email = '0406adem@gmail.com';
const linkedin = 'https://www.linkedin.com/in/adem-kocyigit';
---

<!-- Mobile top bar -->
<header
  class="fixed inset-x-0 top-0 z-40 flex h-16 items-center justify-between border-b border-ink-line bg-ink/90 px-5 backdrop-blur lg:hidden"
>
  <a href={home} class="font-heading text-base font-bold tracking-tightish text-paper">ADEM KOCYIGIT</a>
  <button id="menu-btn" aria-label={t(lang, 'mobile.menu')} class="p-2 text-paper">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>
</header>

<!-- Backdrop (mobile) -->
<div
  id="menu-backdrop"
  class="pointer-events-none fixed inset-0 z-40 bg-black/60 opacity-0 transition-opacity duration-300 lg:hidden"
>
</div>

<!-- Sidebar / off-canvas drawer -->
<aside
  id="sidebar"
  class="fixed inset-y-0 left-0 z-50 flex w-[300px] max-w-[85vw] -translate-x-full flex-col overflow-y-auto border-r border-ink-line bg-ink px-7 py-8 transition-transform duration-300 lg:translate-x-0"
>
  <!-- Brand -->
  <a href={home} class="group block">
    <div
      class="font-heading text-[28px] font-bold leading-[0.95] tracking-tightish text-paper transition-colors group-hover:text-amber-bright"
    >
      Adem<br />Kocyigit
    </div>
    <div class="mt-2.5 text-[11px] uppercase tracking-[0.18em] text-fog">{t(lang, 'site.role')}</div>
  </a>

  <!-- Navigation -->
  <nav class="mt-10 flex-1">
    <div class="mb-3 text-[11px] uppercase tracking-[0.2em] text-fog/60">{t(lang, 'nav.work')}</div>
    <ul class="space-y-2 text-[15px]">
      <li><a class="nav-link" data-filter="featured" href={`${home}#featured`}>{t(lang, 'filter.featured')}</a></li>
      <li><a class="nav-link" data-filter="all" href={`${home}#all`}>{t(lang, 'filter.all')}</a></li>
      {
        CATEGORIES.map((c) => (
          <li>
            <a class="nav-link" data-filter={c.key} href={`${home}#${c.key}`}>
              {catLabel(c, lang)}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="mb-3 mt-9 text-[11px] uppercase tracking-[0.2em] text-fog/60">{t(lang, 'nav.menu')}</div>
    <ul class="space-y-2 text-[15px]">
      <li><a class:list={['nav-link', isPage(about) && 'is-active']} href={about}>{t(lang, 'nav.about')}</a></li>
      <li><a class:list={['nav-link', isPage(contact) && 'is-active']} href={contact}>{t(lang, 'nav.contact')}</a></li>
    </ul>
  </nav>

  <!-- Bottom: language + contact -->
  <div class="mt-8 space-y-4 border-t border-ink-line pt-6">
    <div class="flex items-center gap-2 text-xs tracking-wider" aria-label={t(lang, 'lang.aria')}>
      {
        lang === 'de' ? (
          <>
            <span class="font-medium text-amber-bright" aria-current="true">{t(lang, 'lang.de')}</span>
            <span class="text-fog/40">/</span>
            <a href={alternateHref} class="text-fog transition-colors hover:text-paper">{t(lang, 'lang.en')}</a>
          </>
        ) : (
          <>
            <a href={alternateHref} class="text-fog transition-colors hover:text-paper">{t(lang, 'lang.de')}</a>
            <span class="text-fog/40">/</span>
            <span class="font-medium text-amber-bright" aria-current="true">{t(lang, 'lang.en')}</span>
          </>
        )
      }
    </div>
    <a href={`mailto:${email}`} class="block break-all text-sm text-fog transition-colors hover:text-paper">{email}</a>
    <a href={linkedin} target="_blank" rel="noopener" class="block text-sm text-fog transition-colors hover:text-paper">
      LinkedIn ↗
    </a>
  </div>
</aside>

<script>
  const btn = document.getElementById('menu-btn');
  const sb = document.getElementById('sidebar');
  const bd = document.getElementById('menu-backdrop');

  const open = () => {
    sb?.classList.remove('-translate-x-full');
    bd?.classList.remove('opacity-0', 'pointer-events-none');
  };
  const close = () => {
    sb?.classList.add('-translate-x-full');
    bd?.classList.add('opacity-0', 'pointer-events-none');
  };

  btn?.addEventListener('click', open);
  bd?.addEventListener('click', close);
  sb?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      if (window.innerWidth < 1024) close();
    })
  );
</script>
