---
import { catLabel, getCategory, type Project, type Lang } from '../data/projects';
import { t } from '../i18n/ui';

interface Props {
  project: Project;
  lang: Lang;
}
const { project, lang } = Astro.props;

const cat = getCategory(project.category);
const catName = cat ? catLabel(cat, lang) : project.category;
const role = project.role[lang];

const isLink = !!project.link;
const playable = project.video.type !== 'none';
const videoType = project.video.type;
const videoId = project.video.type === 'none' ? '' : project.video.id;

const initials =
  project.title
    .replace(/[^A-Za-zÄÖÜäöü0-9 ]/g, ' ')
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((w) => w[0])
    .join('')
    .toUpperCase() || 'AK';

const Tag = isLink ? 'a' : 'button';
const attrs = isLink
  ? { href: project.link, target: '_blank', rel: 'noopener' }
  : {
      type: 'button',
      'data-video': '',
      'data-video-type': videoType,
      'data-video-id': videoId,
      'data-title': project.title,
    };
---

<Tag
  class="group block w-full text-left reveal"
  data-project
  data-category={project.category}
  data-featured={project.featured ? 'true' : 'false'}
  {...attrs}
>
  <div class="relative aspect-video overflow-hidden rounded-lg border border-ink-line bg-ink-soft">
    {
      project.thumbnail ? (
        <img
          src={project.thumbnail}
          alt={project.title}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
        />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center bg-[radial-gradient(circle_at_30%_20%,#181818,#0d0d0d)]">
          <span class="select-none font-heading text-6xl font-bold text-ink-line">{initials}</span>
        </div>
      )
    }

    <!-- gradient -->
    <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-transparent to-transparent"></div>

    <!-- category tag -->
    <span
      class="absolute left-3 top-3 rounded bg-ink/80 px-2 py-1 text-[10px] font-medium uppercase tracking-wider text-amber-bright backdrop-blur"
      >{catName}</span
    >

    <!-- hover CTA -->
    <div
      class="absolute inset-0 flex items-center justify-center bg-ink/50 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
    >
      <span class="flex items-center gap-2 rounded-full bg-amber px-5 py-2.5 text-sm font-medium text-ink">
        {
          isLink ? (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M9 7h8v8" />
            </svg>
          ) : (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z" />
            </svg>
          )
        }
        {isLink ? t(lang, 'card.external') : t(lang, 'card.watch')}
      </span>
    </div>
  </div>

  <!-- meta -->
  <div class="mt-3 flex items-baseline justify-between gap-3">
    <h3 class="font-heading text-lg font-semibold text-paper transition-colors group-hover:text-amber-bright">
      {project.title}
    </h3>
    <span class="shrink-0 text-xs text-fog">{project.year}</span>
  </div>
  <p class="mt-0.5 text-sm text-fog">{role}</p>
</Tag>
