---
import { type Project, type Lang } from '../data/projects';
interface Props {
  project: Project;
  lang: Lang;
}
const { project, lang } = Astro.props;

const role = project.role[lang];
const isLink = !!project.link;
const videoType = project.video.type;
const videoId = project.video.type === 'none' ? '' : project.video.id;

const initials =
  project.title
    .replace(/[^A-Za-zÄÖÜäöü0-9 ]/g, ' ')
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((w) => w[0])
    .join('')
    .toUpperCase() || 'AK';

const Tag = isLink ? 'a' : 'button';
const attrs = isLink
  ? { href: project.link, target: '_blank', rel: 'noopener' }
  : {
      type: 'button',
      'data-video': '',
      'data-video-type': videoType,
      'data-video-id': videoId,
      'data-title': project.title,
    };
---

<li>
  <Tag
    class="work-row group flex w-full items-baseline justify-between gap-6 border-b border-ink-line py-5 text-left"
    data-project
    data-category={project.category}
    data-featured={project.featured ? 'true' : 'false'}
    data-thumb={project.thumbnail ?? ''}
    data-initials={initials}
    {...attrs}
  >
    <span
      class="font-heading text-2xl font-semibold leading-tight text-paper transition-all duration-300 group-hover:translate-x-1.5 group-hover:text-amber-bright sm:text-[28px]"
    >
      {project.title}{isLink ? ' ↗' : ''}
    </span>
    <span class="shrink-0 pt-1 text-right text-sm text-fog">
      <span class="hidden sm:inline">{role} · </span>{project.year}
    </span>
  </Tag>
</li>
