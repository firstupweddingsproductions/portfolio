---
import { t } from '../i18n/ui';
import type { Lang } from '../i18n/routes';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const closeLabel = t(lang, 'lightbox.close');
const soonText = lang === 'en' ? 'Preview coming soon.' : 'Vorschau folgt in Kürze.';
const downloadLabel = lang === 'en' ? 'Download project folder' : 'Projektordner herunterladen';
const tabVideo = 'Video';
const tabPhotos = lang === 'en' ? 'Photos' : 'Fotos';
---

<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center overflow-y-auto p-4 py-10 sm:p-8"
  role="dialog"
  aria-modal="true"
  aria-label="Media"
>
  <div data-lb-close class="fixed inset-0 bg-black/85 backdrop-blur-sm"></div>

  <div class="relative z-10 my-auto w-full max-w-5xl">
    <button
      data-lb-close
      aria-label={closeLabel}
      class="absolute -top-9 right-0 flex items-center gap-1.5 text-sm text-paper/80 transition-colors hover:text-amber-bright"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" />
      </svg>
      {closeLabel}
    </button>

    <!-- Tabs (only when a project has both a video and a photo slideshow) -->
    <div id="lb-tabs" class="mb-3 hidden gap-2 text-sm">
      <button data-tab="video" class="lb-tab rounded-full border border-ink-line px-4 py-1.5 transition-colors">{tabVideo}</button>
      <button data-tab="photos" class="lb-tab rounded-full border border-ink-line px-4 py-1.5 transition-colors">{tabPhotos}</button>
    </div>

    <div class="relative aspect-video w-full overflow-hidden rounded-lg border border-ink-line bg-ink shadow-2xl">
      <iframe
        id="lb-frame"
        class="absolute inset-0 hidden h-full w-full"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        referrerpolicy="strict-origin-when-cross-origin"
        title="Player"></iframe>

      <img id="lb-image" class="absolute inset-0 hidden h-full w-full object-contain" alt="" />

      <div id="lb-soon" class="absolute inset-0 hidden flex-col items-center justify-center gap-3 px-6 text-center">
        <span class="flex h-16 w-16 items-center justify-center rounded-full bg-amber/15">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-amber-bright" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
        </span>
        <p class="text-sm text-fog">{soonText}</p>
      </div>

      <button id="lb-prev" class="absolute left-2 top-1/2 hidden -translate-y-1/2 rounded-full bg-ink/70 p-2 text-paper transition-colors hover:bg-ink/95" aria-label="Previous">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 18l-6-6 6-6" /></svg>
      </button>
      <button id="lb-next" class="absolute right-2 top-1/2 hidden -translate-y-1/2 rounded-full bg-ink/70 p-2 text-paper transition-colors hover:bg-ink/95" aria-label="Next">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6l6 6-6 6" /></svg>
      </button>
      <div id="lb-counter" class="absolute bottom-2 right-3 hidden rounded bg-ink/70 px-2 py-1 text-xs text-paper"></div>
    </div>

    <div class="mt-5">
      <div class="flex items-baseline justify-between gap-4">
        <h3 id="lb-title" class="font-heading text-xl font-semibold text-paper sm:text-2xl"></h3>
        <span id="lb-year" class="shrink-0 text-sm text-fog"></span>
      </div>
      <p id="lb-meta" class="mt-1 text-sm text-amber-bright"></p>
      <p id="lb-desc" class="mt-3 max-w-3xl text-sm leading-relaxed text-fog"></p>
      <a
        id="lb-download"
        href="#"
        target="_blank"
        rel="noopener"
        class="mt-4 hidden items-center gap-2 rounded-full bg-amber px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:bg-amber-bright"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14" /></svg>
        {downloadLabel}
      </a>
    </div>
  </div>
</div>

<script>
  const lb = document.getElementById('lightbox');
  const frame = document.getElementById('lb-frame') as HTMLIFrameElement | null;
  const img = document.getElementById('lb-image') as HTMLImageElement | null;
  const soon = document.getElementById('lb-soon');
  const prev = document.getElementById('lb-prev');
  const next = document.getElementById('lb-next');
  const counter = document.getElementById('lb-counter');
  const tabs = document.getElementById('lb-tabs');
  const tabBtns = Array.from(document.querySelectorAll<HTMLElement>('.lb-tab'));
  const elTitle = document.getElementById('lb-title');
  const elYear = document.getElementById('lb-year');
  const elMeta = document.getElementById('lb-meta');
  const elDesc = document.getElementById('lb-desc');
  const elDownload = document.getElementById('lb-download') as HTMLAnchorElement | null;

  let gallery: string[] = [];
  let gi = 0;
  let videoSrc = '';

  function srcFor(type: string | null, id: string | null): string {
    if (!id) return '';
    if (type === 'vimeo') return `https://player.vimeo.com/video/${id}?autoplay=1&title=0&byline=0&portrait=0`;
    if (type === 'drive') return `https://drive.google.com/file/d/${id}/preview`;
    return '';
  }

  function showGalleryImage() {
    if (!img || !counter) return;
    img.src = gallery[gi];
    counter.textContent = `${gi + 1} / ${gallery.length}`;
  }
  function step(d: number) {
    if (gallery.length < 2) return;
    gi = (gi + d + gallery.length) % gallery.length;
    showGalleryImage();
  }

  function showVideoPane() {
    img?.classList.add('hidden');
    prev?.classList.add('hidden');
    next?.classList.add('hidden');
    counter?.classList.add('hidden');
    if (videoSrc && frame) {
      frame.src = videoSrc;
      frame.classList.remove('hidden');
      soon?.classList.add('hidden');
      soon?.classList.remove('flex');
    } else {
      frame?.classList.add('hidden');
      soon?.classList.remove('hidden');
      soon?.classList.add('flex');
    }
  }
  function showGalleryPane() {
    if (frame) frame.src = '';
    frame?.classList.add('hidden');
    soon?.classList.add('hidden');
    soon?.classList.remove('flex');
    img?.classList.remove('hidden');
    showGalleryImage();
    if (gallery.length > 1) { prev?.classList.remove('hidden'); next?.classList.remove('hidden'); }
    counter?.classList.remove('hidden');
  }
  function setActiveTab(tab: string) {
    tabBtns.forEach((b) => {
      const on = b.getAttribute('data-tab') === tab;
      b.classList.toggle('bg-amber', on);
      b.classList.toggle('text-ink', on);
      b.classList.toggle('text-fog', !on);
    });
    if (tab === 'photos') showGalleryPane();
    else showVideoPane();
  }

  function open(el: HTMLElement) {
    if (!lb) return;
    if (elTitle) elTitle.textContent = el.getAttribute('data-title') || '';
    if (elYear) elYear.textContent = el.getAttribute('data-year') || '';
    if (elMeta) elMeta.textContent = [el.getAttribute('data-cat'), el.getAttribute('data-role')].filter(Boolean).join(' · ');
    if (elDesc) elDesc.textContent = el.getAttribute('data-desc') || '';

    const dl = el.getAttribute('data-download');
    if (elDownload) {
      elDownload.classList.toggle('hidden', !dl);
      elDownload.classList.toggle('inline-flex', !!dl);
      if (dl) elDownload.href = dl;
    }

    // panes
    try { gallery = JSON.parse(el.getAttribute('data-gallery') || '[]'); } catch { gallery = []; }
    gi = 0;
    const vtype = el.getAttribute('data-video-type');
    videoSrc = srcFor(vtype, el.getAttribute('data-video-id'));
    const hasVideoPane = vtype === 'vimeo' || vtype === 'drive';
    const hasGallery = gallery.length > 0;

    if (frame) frame.src = '';
    if (hasVideoPane && hasGallery) {
      tabs?.classList.remove('hidden');
      tabs?.classList.add('flex');
      setActiveTab('video');
    } else {
      tabs?.classList.add('hidden');
      tabs?.classList.remove('flex');
      if (hasGallery) showGalleryPane();
      else showVideoPane();
    }

    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.classList.add('lightbox-open');
  }

  function close() {
    if (!lb) return;
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    if (frame) frame.src = '';
    if (img) img.src = '';
    gallery = [];
    document.body.classList.remove('lightbox-open');
  }

  prev?.addEventListener('click', (e) => { e.stopPropagation(); step(-1); });
  next?.addEventListener('click', (e) => { e.stopPropagation(); step(1); });
  tabBtns.forEach((b) => b.addEventListener('click', () => setActiveTab(b.getAttribute('data-tab') || 'video')));

  document.querySelectorAll<HTMLElement>('[data-lightbox]').forEach((el) => {
    el.addEventListener('click', () => open(el));
  });
  lb?.querySelectorAll('[data-lb-close]').forEach((b) => b.addEventListener('click', close));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') return close();
    if (lb && !lb.classList.contains('hidden') && !img?.classList.contains('hidden') && gallery.length > 1) {
      if (e.key === 'ArrowLeft') step(-1);
      else if (e.key === 'ArrowRight') step(1);
    }
  });
</script>
