---
import { t } from '../i18n/ui';
import type { Lang } from '../i18n/routes';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const closeLabel = t(lang, 'lightbox.close');
const soonText = lang === 'en' ? 'Preview coming soon.' : 'Vorschau folgt in Kürze.';
---

<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center overflow-y-auto p-4 py-10 sm:p-8"
  role="dialog"
  aria-modal="true"
  aria-label="Video"
>
  <div data-lb-close class="fixed inset-0 bg-black/85 backdrop-blur-sm"></div>

  <div class="relative z-10 my-auto w-full max-w-5xl">
    <button
      data-lb-close
      aria-label={closeLabel}
      class="absolute -top-9 right-0 flex items-center gap-1.5 text-sm text-paper/80 transition-colors hover:text-amber-bright"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" />
      </svg>
      {closeLabel}
    </button>

    <div class="relative aspect-video w-full overflow-hidden rounded-lg border border-ink-line bg-ink-soft shadow-2xl">
      <iframe
        id="lb-frame"
        class="absolute inset-0 hidden h-full w-full"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        referrerpolicy="strict-origin-when-cross-origin"
        title="Video player"></iframe>

      <div id="lb-soon" class="absolute inset-0 hidden flex-col items-center justify-center gap-3 px-6 text-center">
        <span class="flex h-16 w-16 items-center justify-center rounded-full bg-amber/15">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-amber-bright" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z" />
          </svg>
        </span>
        <p class="text-sm text-fog">{soonText}</p>
      </div>
    </div>

    <!-- Info panel under the player -->
    <div id="lb-info" class="mt-5">
      <div class="flex items-baseline justify-between gap-4">
        <h3 id="lb-title" class="font-heading text-xl font-semibold text-paper sm:text-2xl"></h3>
        <span id="lb-year" class="shrink-0 text-sm text-fog"></span>
      </div>
      <p id="lb-meta" class="mt-1 text-sm text-amber-bright"></p>
      <p id="lb-desc" class="mt-3 max-w-3xl text-sm leading-relaxed text-fog"></p>
    </div>
  </div>
</div>

<script>
  const lb = document.getElementById('lightbox');
  const frame = document.getElementById('lb-frame') as HTMLIFrameElement | null;
  const soon = document.getElementById('lb-soon');
  const elTitle = document.getElementById('lb-title');
  const elYear = document.getElementById('lb-year');
  const elMeta = document.getElementById('lb-meta');
  const elDesc = document.getElementById('lb-desc');

  function srcFor(type: string | null, id: string | null): string {
    if (!id) return '';
    if (type === 'vimeo') return `https://player.vimeo.com/video/${id}?autoplay=1&title=0&byline=0&portrait=0`;
    if (type === 'drive') return `https://drive.google.com/file/d/${id}/preview`;
    return '';
  }

  function open(el: HTMLElement) {
    if (!lb || !frame || !soon) return;

    // Info panel
    const title = el.getAttribute('data-title') || '';
    const role = el.getAttribute('data-role') || '';
    const cat = el.getAttribute('data-cat') || '';
    const desc = el.getAttribute('data-desc') || '';
    if (elTitle) elTitle.textContent = title;
    if (elYear) elYear.textContent = el.getAttribute('data-year') || '';
    if (elMeta) elMeta.textContent = [cat, role].filter(Boolean).join(' · ');
    if (elDesc) elDesc.textContent = desc;

    // Player
    const src = srcFor(el.getAttribute('data-video-type'), el.getAttribute('data-video-id'));
    if (!src) {
      frame.classList.add('hidden');
      frame.src = '';
      soon.classList.remove('hidden');
      soon.classList.add('flex');
    } else {
      soon.classList.add('hidden');
      soon.classList.remove('flex');
      frame.src = src;
      frame.classList.remove('hidden');
    }

    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.classList.add('lightbox-open');
  }

  function close() {
    if (!lb || !frame) return;
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    frame.src = ''; // stop playback
    document.body.classList.remove('lightbox-open');
  }

  document.querySelectorAll<HTMLElement>('[data-video]').forEach((el) => {
    el.addEventListener('click', () => open(el));
  });

  lb?.querySelectorAll('[data-lb-close]').forEach((b) => b.addEventListener('click', close));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });
</script>
