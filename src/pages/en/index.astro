---
import Layout from '../../layouts/Layout.astro';
import WorkList from '../../components/WorkList.astro';
const lang = 'en';
---

<Layout title="Work" lang={lang}>
  <div class="px-6 pt-10 md:px-10 lg:px-14 lg:pt-16">
    <section class="reveal mb-12 max-w-2xl">
      <p class="mb-3 text-xs uppercase tracking-[0.25em] text-amber">Portfolio</p>
      <h1 class="font-heading text-2xl font-medium leading-snug tracking-tightish text-paper sm:text-3xl">
        Film, video & visual storytelling — from concept to final cut.
      </h1>
    </section>

    <WorkList lang={lang} />
  </div>
</Layout>
