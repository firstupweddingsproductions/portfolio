---
import Layout from '../../layouts/Layout.astro';
import FilterBar from '../../components/FilterBar.astro';
import WorkList from '../../components/WorkList.astro';
const lang = 'en';
---

<Layout title="Work" lang={lang}>
  <section class="reveal mb-10 max-w-3xl">
    <p class="mb-3 text-xs uppercase tracking-[0.25em] text-amber">Portfolio</p>
    <h1 class="font-heading text-4xl font-bold leading-tight tracking-tightish text-paper sm:text-5xl">
      Film, video & <span class="text-amber-bright">visual storytelling</span> — from concept to final cut.
    </h1>
    <p class="mt-4 text-sm text-fog">
      A focused selection of my work — more projects available on request.
    </p>
  </section>

  <FilterBar lang={lang} />
  <WorkList lang={lang} />
</Layout>
