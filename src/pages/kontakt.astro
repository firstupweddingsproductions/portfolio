---
import Layout from '../layouts/Layout.astro';
const lang = 'de';
const email = '0406adem@gmail.com';
const phone = '+49 173 2118910';
const linkedin = 'https://www.linkedin.com/in/adem-kocyigit';

const rows = [
  { label: 'E-Mail', value: email, href: `mailto:${email}`, ext: false },
  { label: 'Telefon', value: phone, href: 'tel:+491732118910', ext: false },
  { label: 'LinkedIn', value: 'adem-kocyigit', href: linkedin, ext: true },
];
---

<Layout title="Kontakt" lang={lang}>
  <div class="px-6 pt-10 md:px-10 lg:px-14 lg:pt-16">
    <div class="max-w-3xl">
      <p class="reveal mb-4 text-xs uppercase tracking-[0.25em] text-amber">Kontakt</p>
      <h1 class="reveal font-heading text-4xl font-bold leading-tight tracking-tightish text-paper sm:text-5xl">
        Lass uns etwas <span class="text-amber-bright">erschaffen</span>.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-fog">
        Ob Anfrage, Projekt oder einfach ein Hallo — ich freue mich, von dir zu hören.
      </p>

      <div class="mt-10 overflow-hidden rounded-lg border border-ink-line">
        {rows.map((r) => (
          <a
            href={r.href}
            target={r.ext ? '_blank' : undefined}
            rel={r.ext ? 'noopener' : undefined}
            class="group flex items-center justify-between border-b border-ink-line bg-ink-soft px-5 py-5 transition-colors last:border-b-0 hover:bg-ink-line"
          >
            <span class="text-xs uppercase tracking-[0.2em] text-fog">{r.label}</span>
            <span class="font-heading text-base text-paper transition-colors group-hover:text-amber-bright">
              {r.value}{r.ext ? ' ↗' : ''}
            </span>
          </a>
        ))}
      </div>

      <p class="mt-8 text-sm text-fog">Standort: Kiel, Schleswig-Holstein · Deutschland</p>
    </div>
  </div>
</Layout>
